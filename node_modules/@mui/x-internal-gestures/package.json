{
  "name": "@mui/x-internal-gestures",
  "version": "9.7.0",
  "author": "MUI Team",
  "description": "The core engine of GestureEvents, a modern and robust multi-pointer gesture detection library for JavaScript.",
  "license": "MIT",
  "keywords": [
    "multitouch",
    "gesture",
    "library",
    "wheel",
    "pan",
    "pinch",
    "move",
    "rotate",
    "press",
    "tap",
    "simultaneous",
    "gestures",
    "pointer",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/mui/mui-x/issues"
  },
  "homepage": "https://mui.com/x/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mui/mui-x.git",
    "directory": "packages/x-internal-gestures"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@base-ui/utils": "^0.3.0"
  },
  "sideEffects": false,
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./core": {
      "import": {
        "types": "./core/index.d.mts",
        "default": "./core/index.mjs"
      },
      "require": {
        "types": "./core/index.d.ts",
        "default": "./core/index.js"
      },
      "default": {
        "types": "./core/index.d.mts",
        "default": "./core/index.mjs"
      }
    },
    "./matchers": {
      "import": {
        "types": "./matchers/index.d.mts",
        "default": "./matchers/index.mjs"
      },
      "require": {
        "types": "./matchers/index.d.ts",
        "default": "./matchers/index.js"
      },
      "default": {
        "types": "./matchers/index.d.mts",
        "default": "./matchers/index.mjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./testing/index.d.mts",
        "default": "./testing/index.mjs"
      },
      "require": {
        "types": "./testing/index.d.ts",
        "default": "./testing/index.js"
      },
      "default": {
        "types": "./testing/index.d.mts",
        "default": "./testing/index.mjs"
      }
    }
  },
  "imports": {
    "#formatErrorMessage": {
      "import": {
        "types": "./formatErrorMessage.d.mts",
        "default": "./formatErrorMessage.mjs"
      },
      "require": {
        "types": "./formatErrorMessage.d.ts",
        "default": "./formatErrorMessage.js"
      },
      "default": {
        "types": "./formatErrorMessage.d.mts",
        "default": "./formatErrorMessage.mjs"
      }
    }
  }
}